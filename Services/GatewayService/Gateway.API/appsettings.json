{
  "ReverseProxy": {
    "Routes": {
      "identityRoute": {
        "ClusterId": "identityCluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "taskRoute": {
        "ClusterId": "taskCluster",
        "Match": {
          "Path": "/tasks/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identityCluster": {
        "Destinations": {
          "d1": {
            "Address": "https://identity-service-qofo.onrender.com/"
          }
        }
      },
      "taskCluster": {
        "Destinations": {
          "d1": {
            "Address": "https://task-service-hdk8.onrender.com/"
          }
        }
      }
    }
  }
}