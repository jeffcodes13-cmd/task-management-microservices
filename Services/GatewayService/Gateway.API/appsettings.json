{
  "ReverseProxy": {
    "Routes": {
      "identityRoute": {
        "ClusterId": "identityCluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/identity" }
        ]
      },
      "taskRoute": {
        "ClusterId": "taskCluster",
        "Match": {
          "Path": "/tasks/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/tasks" }
        ]
      }
    },
    "Clusters": {
      "identityCluster": {
        "Destinations": {
          "d1": {
            "Address": ""
          }
        }
      },
      "taskCluster": {
        "Destinations": {
          "d1": {
            "Address": ""
          }
        }
      }
    }
  }
}